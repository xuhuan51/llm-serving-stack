{
  "title": "vLLM Serving SLO",
  "uid": "vllm-slo-v2",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "QPS (success requests / sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(vllm:request_success_total[1m]))",
          "legendFormat": "QPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "TTFT P95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket[1m])))",
          "legendFormat": "TTFT P95"
        }
      ]
    },
    {
      "id": 3,
      "title": "TPOT P95 (s/token)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:request_time_per_output_token_seconds_bucket[1m])))",
          "legendFormat": "TPOT P95"
        }
      ]
    },
    {
      "id": 4,
      "title": "E2E Latency P95 / P99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket[1m])))",
          "legendFormat": "P95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket[1m])))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 5,
      "title": "Running / Waiting Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm:num_requests_running",
          "legendFormat": "running"
        },
        {
          "refId": "B",
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting"
        }
      ]
    },
    {
      "id": 6,
      "title": "GPU KV Cache Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "KV cache"
        }
      ]
    }
  ]
}
