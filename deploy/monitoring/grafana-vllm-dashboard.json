{
  "title": "vLLM Serving SLO",
  "uid": "vllm-slo-v3",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "QPS (success requests / sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(vllm:request_success_total[1m]))", "legendFormat": "QPS" }
      ]
    },
    {
      "id": 2,
      "title": "TTFT P95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket[1m])))", "legendFormat": "TTFT P95" }
      ]
    },
    {
      "id": 3,
      "title": "TPOT P95 (s/token)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:request_time_per_output_token_seconds_bucket[1m])))", "legendFormat": "TPOT P95" }
      ]
    },
    {
      "id": 4,
      "title": "E2E Latency P95 / P99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket[1m])))", "legendFormat": "P95" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket[1m])))", "legendFormat": "P99" }
      ]
    },
    {
      "id": 5,
      "title": "Running / Waiting Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "vllm:num_requests_running", "legendFormat": "running" },
        { "refId": "B", "expr": "vllm:num_requests_waiting", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 6,
      "title": "GPU KV Cache Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "refId": "A", "expr": "vllm:kv_cache_usage_perc", "legendFormat": "KV cache" }
      ]
    },
    {
      "id": 7,
      "title": "Prefill vs Decode P95 (s) — TTFT 拆解",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:request_prefill_time_seconds_bucket[1m])))", "legendFormat": "prefill P95" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:request_decode_time_seconds_bucket[1m])))", "legendFormat": "decode P95" }
      ]
    },
    {
      "id": 8,
      "title": "Queue Time P95 (s) — 排队等待",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:request_queue_time_seconds_bucket[1m])))", "legendFormat": "queue P95" }
      ]
    },
    {
      "id": 9,
      "title": "Preemption Rate (events/sec) — KV 抢占信号",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "expr": "rate(vllm:num_preemptions_total[1m])", "legendFormat": "preemptions/s" }
      ]
    },
    {
      "id": 10,
      "title": "Prefix Cache Hit Rate (%) — 长 prompt 复用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(vllm:prefix_cache_hits_total[1m])) / clamp_min(sum(rate(vllm:prefix_cache_queries_total[1m])), 1)", "legendFormat": "hit rate" }
      ]
    },
    {
      "id": 11,
      "title": "Token Throughput (tokens/sec) — Prompt vs Generation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(vllm:prompt_tokens_total[1m]))", "legendFormat": "prompt tokens/s" },
        { "refId": "B", "expr": "sum(rate(vllm:generation_tokens_total[1m]))", "legendFormat": "generation tokens/s" }
      ]
    }
  ]
}
